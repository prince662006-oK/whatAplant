Options -Indexes

# ── Types MIME corrects pour PWA ──
AddType application/manifest+json .json
AddType application/javascript    .js
AddType image/png                 .png
AddType text/css                  .css

# ── Headers pour sw.js (Service Worker) ──
<FilesMatch "sw\.js$">
    Header set Content-Type "application/javascript"
    Header set Service-Worker-Allowed "/"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# ── Headers pour manifest.json ──
<FilesMatch "manifest\.json$">
    Header set Content-Type "application/manifest+json"
    Header set Cache-Control "public, max-age=86400"
</FilesMatch>

# ── Headers CORS pour les icônes PWA ──
<FilesMatch "\.(png|ico|jpg|jpeg|svg|webp)$">
    Header set Access-Control-Allow-Origin "*"
    Header set Cache-Control "public, max-age=604800"
</FilesMatch>

# ── Compression GZIP ──
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Protection du dossier uploads ──
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Bloquer l'exécution de PHP dans uploads/
    RewriteRule ^uploads/.*\.php$ - [F,L]
</IfModule>

# ── Sécurité ──
<FilesMatch "\.(sql|env|log|sh)$">
    Order allow,deny
    Deny from all
</FilesMatch>
