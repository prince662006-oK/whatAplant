Options -Indexes

# Désactive complètement le routing pour tester
# RewriteEngine Off

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Servir les vrais fichiers s'ils existent (priorité maximale)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Exclure explicitement manifest et sw
    RewriteCond %{REQUEST_URI} ^/manifest\.json$ [OR]
    RewriteCond %{REQUEST_URI} ^/sw\.js$ [OR]
    RewriteCond %{REQUEST_URI} ^/icons/
    RewriteRule ^ - [L]

    # Tout le reste → index.php
    RewriteRule ^ index.php [L]
</IfModule>

# Headers pour PWA
<Files "manifest.json">
    Header set Content-Type "application/json; charset=utf-8"
</Files>

<Files "sw.js">
    Header set Content-Type "application/javascript"
    Header set Service-Worker-Allowed "/"
</Files>
